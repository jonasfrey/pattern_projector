{
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-write --allow-run --allow-env main.ts",
    "dev": "deno run --allow-net --allow-read --allow-write --allow-run --allow-env --watch main.ts",
    "test": "deno test --allow-net --allow-read --allow-write --allow-run --allow-env",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "std/": "https://deno.land/std@0.224.0/"
  },
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "fmt": {
    "exclude": ["public/", "storage/"]
  },
  "lint": {
    "exclude": ["public/", "storage/"]
  }
}
